# MediChain Backend - Environment Template
# Rename this to .env and fill in the values

# 1. Blockchain (Sepolia Testnet)
# Get a free key at infura.io or alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# THE HOSPITAL_PRIVATE_KEY should be a fresh wallet with ~0.05 Sepolia ETH
HOSPITAL_PRIVATE_KEY=your_private_key_here

# Deployed Contract Address (Already set for Sepolia)
VITE_CONTRACT_ADDRESS=0x9D54eE261aA4f574D6e2A9CDD1d02eBA5A1C9B13

# 2. IPFS (Pinata)
# Get these at pinata.cloud (Leave blank to use Simulation Mode)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# 3. Server Configuration
PORT=8080
NODE_ENV=development
